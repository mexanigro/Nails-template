# Server-only: Google AI credentials used by Express (`server.ts`). Never bundled into the Vite client.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Stripe Configuration
# Get these from your Stripe Dashboard (Developers > API keys)
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Notification Configuration
# The final recipient for all business owner notifications
BUSINESS_OWNER_EMAIL=owner@example.com

# Specific notification recipients (fallback to BUSINESS_OWNER_EMAIL if empty)
BOOKING_NOTIFICATION_EMAIL=
CONTACT_NOTIFICATION_EMAIL=

# Email Provider (e.g., SendGrid, Mailgun, or Resend API key)
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=notifications@yourdomain.com

# Admin Authentication
# The only email authorized to access the Mission Control dashboard via Google Sign-In
VITE_ADMIN_EMAIL=
